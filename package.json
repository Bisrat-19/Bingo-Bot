{
  "name": "telegram-bingo-bot",
  "version": "2.0.0",
  "description": "Multiplayer Bingo — Telegram bot + Mini App in one Next.js app (Prisma, PostgreSQL).",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "node --env-file=.env node_modules/.bin/tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@telegram-apps/sdk-react": "^3.3.9",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "next": "^15.1.3",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
