// Prisma schema — continuous global Bingo room.
// One always-running room cycles: SELECTING (30s after first pick) -> PLAYING -> FINISHED
// (winner shown briefly) -> next round.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoundStatus {
  SELECTING // card selection open
  PLAYING   // numbers being called
  FINISHED  // winner (or no winner) — shown briefly before the next round
}

/// Runtime-editable game configuration (single row, id = 1). Admins change these from
/// the Mini App without a redeploy.
model Settings {
  id                    Int      @id @default(1)
  selectionSeconds      Int      @default(30) // card-selection window after the first pick
  drawIntervalSeconds   Int      @default(5) // gap between called numbers
  winnerDisplaySeconds  Int      @default(8) // how long the winner splash shows
  minPlayers            Int      @default(1) // players required to start a round
  startingCoins         Int      @default(30) // coins a new player receives
  entryFee              Int      @default(10) // coins charged to take a card
  falseBingoCooldownSec Int      @default(0) // 0 = no cooldown, just an error message
  /// Which patterns count as a win: HORIZONTAL, VERTICAL, DIAGONAL, FOUR_CORNERS, FULL_HOUSE
  patterns              String[] @default(["HORIZONTAL", "VERTICAL", "DIAGONAL"])
  /// House cut in percent (1-100). The winner receives (100 - houseCutPercent)% of the pot.
  houseCutPercent       Int      @default(20)
  minDeposit            Int      @default(10)
  minWithdrawal         Int      @default(10)
  /// Telebirr number shown to users on the deposit screen.
  depositPhone          String   @default("0936093033")
  updatedAt             DateTime @updatedAt

  @@map("settings")
}

model User {
  id         String   @id @default(cuid())
  telegramId BigInt   @unique
  username   String?
  firstName  String?
  coins      Int      @default(30)
  /// Collected at registration (shared via Telegram or typed).
  phone      String?
  /// Blocked players can't join rounds (admin control).
  blocked    Boolean  @default(false)
  /// Explicit registration: a row can exist before the player registers, so the bot
  /// knows whether to show the Register button or the main menu.
  registered   Boolean   @default(false)
  registeredAt DateTime?
  createdAt    DateTime  @default(now())

  entries      Entry[]
  wins         Winner[]
  statistics   Statistics?
  transactions Transaction[]
  ledger       LedgerEntry[]

  @@map("users")
}

/// The FIXED catalog of 100 playable cards. Card #7 always has the same numbers.
model BingoCard {
  number  Int  @id // 1..100
  numbers Json // 5x5 matrix, 0 = FREE centre

  entries Entry[]

  @@map("bingo_cards")
}

model Round {
  id              String      @id @default(cuid())
  status          RoundStatus @default(SELECTING)
  /// When the 30s selection window closes. Set when the FIRST player picks a card.
  selectionEndsAt DateTime?
  currentNumber   Int?
  winnerId        String? // scalar (not FK) so the winner claim stays a single atomic update
  winnerCardNo    Int?
  winnerPattern   String? // HORIZONTAL / VERTICAL / DIAGONAL
  winnerLine      Int[]   @default([]) // the numbers forming the winning line (for highlighting)
  pot             Int     @default(0) // coins staked this round; paid to the winner
  entryFee        Int     @default(0) // fee charged this round (snapshot of settings)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime    @default(now())

  entries Entry[]
  calls   Call[]
  winner  Winner?

  @@index([status])
  @@map("rounds")
}

/// A player's participation in one round, holding the card they picked.
model Entry {
  id         String   @id @default(cuid())
  roundId    String
  round      Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  cardNumber Int
  card       BingoCard @relation(fields: [cardNumber], references: [number])
  marked     Int[]    @default([])
  hasBingo   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([roundId, cardNumber]) // one card can be held by only ONE player per round
  @@unique([roundId, userId]) // and each player holds only ONE card per round
  @@index([roundId])
  @@map("entries")
}

model Call {
  id       String   @id @default(cuid())
  roundId  String
  round    Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  number   Int
  order    Int // 1-based draw order
  calledAt DateTime @default(now())

  @@unique([roundId, number]) // a number is never called twice in a round
  @@index([roundId])
  @@map("calls")
}

model Winner {
  id            String   @id @default(cuid())
  roundId       String   @unique
  round         Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  cardNumber    Int
  pattern       String // HORIZONTAL / VERTICAL / DIAGONAL
  numbersCalled Int
  durationMs    Int
  createdAt     DateTime @default(now())

  @@map("winners")
}

model Statistics {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  gamesPlayed  Int      @default(0)
  gamesWon     Int      @default(0)
  bingosCalled Int      @default(0)
  falseBingos  Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@map("statistics")
}


enum TxType {
  DEPOSIT
  WITHDRAWAL
}

enum TxStatus {
  PENDING
  APPROVED
  REJECTED
}

/// A deposit or withdrawal request awaiting admin review.
model Transaction {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id])
  type   TxType
  status TxStatus @default(PENDING)

  /// Amount the player declared (coins == birr, 1:1).
  amount         Int
  /// What the admin actually approved — may differ from the declared amount.
  approvedAmount Int?

  fullName String
  phone    String
  /// Telegram file_id of the receipt photo (deposits only).
  receiptFileId String?

  /// The receipt image itself, stored by us (see ReceiptFile).
  receipt ReceiptFile?

  adminNote  String?
  reviewedBy String? // admin telegram id
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([status, createdAt])
  @@index([userId])
  @@map("transactions")
}

enum LedgerReason {
  DEPOSIT
  WITHDRAWAL_HOLD
  WITHDRAWAL_REFUND
  ENTRY_FEE
  PRIZE
  ROUND_REFUND
  ADMIN_ADJUST
  BONUS
}

/// Immutable audit trail: every coin movement, with the resulting balance.
model LedgerEntry {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  delta        Int // positive = credit, negative = debit
  balanceAfter Int
  reason       LedgerReason
  /// transaction id / round id that caused this movement
  refId        String?
  createdAt    DateTime     @default(now())

  @@index([userId, createdAt])
  @@map("ledger_entries")
}


/// The deposit receipt image, stored in our own database.
///
/// Telegram file_ids are tied to the bot token and their download links expire, so for
/// financial evidence we keep our own copy. Held in a separate table so listing
/// transactions never drags the blobs along.
model ReceiptFile {
  id        String      @id @default(cuid())
  txId      String      @unique
  tx        Transaction @relation(fields: [txId], references: [id], onDelete: Cascade)
  mimeType  String      @default("image/jpeg")
  sizeBytes Int
  data      Bytes
  createdAt DateTime    @default(now())

  @@map("receipt_files")
}
