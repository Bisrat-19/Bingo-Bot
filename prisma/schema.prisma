// Prisma schema — continuous global Bingo room.
// One always-running room cycles: SELECTING (30s after first pick) -> PLAYING -> FINISHED
// (winner shown briefly) -> next round.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoundStatus {
  SELECTING // card selection open
  PLAYING   // numbers being called
  FINISHED  // winner (or no winner) — shown briefly before the next round
}

model User {
  id         String   @id @default(cuid())
  telegramId BigInt   @unique
  username   String?
  firstName  String?
  createdAt  DateTime @default(now())

  entries    Entry[]
  wins       Winner[]
  statistics Statistics?

  @@map("users")
}

/// The FIXED catalog of 100 playable cards. Card #7 always has the same numbers.
model BingoCard {
  number  Int  @id // 1..100
  numbers Json // 5x5 matrix, 0 = FREE centre

  entries Entry[]

  @@map("bingo_cards")
}

model Round {
  id              String      @id @default(cuid())
  status          RoundStatus @default(SELECTING)
  /// When the 30s selection window closes. Set when the FIRST player picks a card.
  selectionEndsAt DateTime?
  currentNumber   Int?
  winnerId        String? // scalar (not FK) so the winner claim stays a single atomic update
  winnerCardNo    Int?
  winnerPattern   String? // HORIZONTAL / VERTICAL / DIAGONAL
  winnerLine      Int[]   @default([]) // the numbers forming the winning line (for highlighting)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime    @default(now())

  entries Entry[]
  calls   Call[]
  winner  Winner?

  @@index([status])
  @@map("rounds")
}

/// A player's participation in one round, holding the card they picked.
model Entry {
  id         String   @id @default(cuid())
  roundId    String
  round      Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  cardNumber Int
  card       BingoCard @relation(fields: [cardNumber], references: [number])
  marked     Int[]    @default([])
  hasBingo   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([roundId, cardNumber]) // one card can be held by only ONE player per round
  @@unique([roundId, userId]) // and each player holds only ONE card per round
  @@index([roundId])
  @@map("entries")
}

model Call {
  id       String   @id @default(cuid())
  roundId  String
  round    Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  number   Int
  order    Int // 1-based draw order
  calledAt DateTime @default(now())

  @@unique([roundId, number]) // a number is never called twice in a round
  @@index([roundId])
  @@map("calls")
}

model Winner {
  id            String   @id @default(cuid())
  roundId       String   @unique
  round         Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  cardNumber    Int
  pattern       String // HORIZONTAL / VERTICAL / DIAGONAL
  numbersCalled Int
  durationMs    Int
  createdAt     DateTime @default(now())

  @@map("winners")
}

model Statistics {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  gamesPlayed  Int      @default(0)
  gamesWon     Int      @default(0)
  bingosCalled Int      @default(0)
  falseBingos  Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@map("statistics")
}
