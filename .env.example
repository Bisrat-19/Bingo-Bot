# ---- Telegram ----
# Create a bot with @BotFather and paste the token here.
BOT_TOKEN=123456:ABC-your-telegram-bot-token-here

# ---- Database (PostgreSQL, runs in Docker via docker-compose) ----
# When running the app on your HOST, use localhost.
# When running the app INSIDE docker-compose, host becomes "postgres" (the service name).
DATABASE_URL=postgresql://bingo:bingo@localhost:5432/bingo?schema=public

# ---- Redis (optional; enables cross-process locking + caching) ----
# Leave REDIS_URL empty to disable Redis entirely (falls back to in-process locking).
REDIS_URL=redis://localhost:6379

# ---- Game defaults (host can override per game) ----
COUNTDOWN_SECONDS=60
DRAW_INTERVAL_SECONDS=10
MIN_PLAYERS=2
MAX_PLAYERS=20
FALSE_BINGO_COOLDOWN_SECONDS=30

# ---- Runtime ----
NODE_ENV=development
LOG_LEVEL=info
